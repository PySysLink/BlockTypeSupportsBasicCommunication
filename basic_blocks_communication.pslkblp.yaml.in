pluginName: basic_blocks_communication
pluginType: coreBlockLibrary
blockType: BasicCommunication
version: @PROJECT_VERSION@
dependsOn:
  - name: BlockTypesBasicCommunication
    version: @PROJECT_VERSION@
blockLibraries:
  - name: BasicBlocksCommunication
    blockTypes:
      - name: OPCUAServer
        configurationValues:
          - name: VariableListFile
            defaultValue: None
            type: string
          - name: OPCUAServerPort
            defaultValue: 4840
            type: int
        inputPortNumber: 0
        outputPortNumber: 1
      - name: ReadValue
        configurationValues:
          - name: VariableName
            defaultValue: None
            type: string
          - name: VariableType
            defaultValue: Double
            type: string
        inputPortNumber: 1
        outputPortNumber: 1
      - name: WriteValue
        configurationValues:
          - name: VariableName
            defaultValue: None
            type: string
          - name: VariableType
            defaultValue: Double
            type: string
        inputPortNumber: 2
        outputPortNumber: 0
          
      